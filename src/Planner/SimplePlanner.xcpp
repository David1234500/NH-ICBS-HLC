struct lessThanByPose2DWithError
{
  bool operator()(const Pose2DWithError& lhs, const Pose2DWithError& rhs) const
  {
    return lhs.error < rhs.error;
  }
};

std::vector<Pose2DWithError> SimpleRoutePlanner::single_step_vehicle_list(Pose2D pose, Pose2D target, bool complete){

    auto config = util::Config::getInstance();
    uint32_t timestep_ms =  config->getIntegerByKey("timestep");
    uint32_t angle_count =  config->getIntegerByKey("angle_count");
    uint32_t vel_count =  config->getIntegerByKey("velocity_count");
    uint32_t branching_count =  config->getIntegerByKey("branching_count");

    std::vector<Pose2DWithError> pose_vector;

    for(uint32_t i = 1; i < angle_count; i ++){
        float next_angle = -SimpleDynamicsModel::angle_limit() + SimpleDynamicsModel::angle_limit() * 2 * (i/(float)angle_count);
        for(uint32_t j = 1; j < vel_count; j ++){
            
            float next_speed = -SimpleDynamicsModel::velocity_limit() + SimpleDynamicsModel::velocity_limit() * 2 * (j/(float)vel_count);

            auto next_pose = SimpleDynamicsModel::computeNextPose(pose, next_angle, next_speed, timestep_ms);
            float error = compute_error(next_pose, target);
            Pose2DWithError next_pose_with_error {next_pose.pos, next_pose.h, next_pose.vel, error};
            pose_vector.push_back(next_pose_with_error);   
        }
    }
    std::sort(pose_vector.begin(), pose_vector.end(), lessThanByPose2DWithError());
    if(!complete){
        pose_vector.resize(branching_count);
    }
    return pose_vector;
}



