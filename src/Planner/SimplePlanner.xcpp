void SimpleRoutePlanner::plan2(){
auto config = util::Config::getInstance();
uint32_t threads =  config->getIntegerByKey("threads");
    
    auto inital = std::make_shared<CombinedSearchNode>();
    for(uint32_t i = 0; i < vehicle_initial_states.size(); i ++){
        inital->predecessor = nullptr;
        inital->vehicle_poses[i] = vehicle_initial_states[i].pose;
    }
    queue.push(inital);

    for(uint32_t i = 0; i < threads; i ++){
        std::thread(&SimpleRoutePlanner::solver_thread, this).detach();
        std::this_thread::sleep_for(std::chrono::milliseconds(20));
    }

    while(!terminate_solver_threads){
        std::this_thread::sleep_for(std::chrono::milliseconds(20));
    }

}

void SimpleRoutePlanner::print(std::string string, int level){
    out_mutex.lock();
    if(level <= 10){
        std::cout << "[Planner] " << string << std::endl;
    }
    out_mutex.unlock();
}

void SimpleRoutePlanner::solver_thread(){
    auto config = util::Config::getInstance();
    uint32_t timestep_ms =  config->getIntegerByKey("timestep");
    uint32_t angle_count =  config->getIntegerByKey("angle_count");
    uint32_t vel_count =  config->getIntegerByKey("velocity_count");
    uint32_t veh_count =  config->getIntegerByKey("vehicle_count");  
    bool first_iteration = true;

    queue_mutex.lock();
    while (!queue.empty() && !terminate_solver_threads){

        //protect with mutex
        std::shared_ptr<CombinedSearchNode> curr = queue.top();
        queue.pop();
        print("Current node with error: " + std::to_string(curr->cumulative_error) + " and count: " +  std::to_string(queue.size()),10);
        queue_mutex.unlock();

        // explore all new options
        std::map<uint32_t, std::vector<dynamics::Pose2DWithError>> vehicle_next_pose_map;
        for(uint32_t k = 0; k < veh_count; k ++){
            vehicle_next_pose_map[k] = single_step_vehicle_list(curr->vehicle_poses[k], vehicle_initial_states[k].target);
        }
        print("Uncombined options with count: " + std::to_string(vehicle_next_pose_map[0].size() * veh_count),20);

        // combine all these options into nodes to explore and compute errors
        auto combined_options = build_options_recursive(0, std::make_shared<CombinedSearchNode>(), vehicle_next_pose_map);
        print("Combined options with count: " + std::to_string(combined_options.size()),10);
        //Compute collision and add to list
        for(auto node: combined_options){
            node->predecessor = curr;
            for(uint32_t j = 0; j < veh_count; j ++){
                for(uint32_t k = j + 1; k < veh_count; k ++){
                    if(compute_intersection(node->vehicle_poses[j],node->vehicle_poses[k])){
                        node->cumulative_error += 10000000.f;
                        print("Detected intersection !",11);
                    }
                }
            }
            bool done = true;
            for(uint32_t j = 0; j < veh_count; j ++){
                if(!compute_error(node->vehicle_poses[j], vehicle_initial_states[j].target) < 10.f){
                    done = false;
                }
            }

            if(done || (curr->cumulative_error < 5.0f && curr->cumulative_error > 0.1f)){
                print("TERMINATE due to done: " + std::to_string(done),5);
                terminate_solver_threads = true;
                solution = curr;
                return;
            }

            queue_mutex.lock();
            queue.push(node);
            queue_mutex.unlock();
            first_iteration = false;
        }
        queue_mutex.lock();
    }
    print("Thread exited !",5);
    queue_mutex.unlock();
}


float SimpleRoutePlanner::compute_error(dynamics::data::Pose2D planned_pose, dynamics::data::Pose2D comparison_point){
    // Consider distance to target location
    float distance = (planned_pose.pos - comparison_point.pos).norm();
    float align_sq = std::pow(planned_pose.h - comparison_point.h, 2);
    return distance; //+ align_sq;
}

bool SimpleRoutePlanner::has_arrived(dynamics::data::Pose2D planned_pose, dynamics::VehicleState current_state){
    // Consider distance to target location
    float distance = (planned_pose.pos - current_state.target.pos).norm();
    float align_sq = std::pow(planned_pose.h - current_state.target.h, 2);
    if(distance < 10 ){//&& align_sq < 10){
        return true;
    }
    return false;
}

bool SimpleRoutePlanner::compute_intersection(dynamics::data::Pose2D planned_pose_a, dynamics::data::Pose2D planned_pose_b){
    float distance = (planned_pose_a.pos - planned_pose_b.pos).norm();
    if(distance < 15.f){
        return true;
    }
    return false;
}

void SimpleRoutePlanner::intitialize_randomly(){
    auto config = util::Config::getInstance();

    for(uint32_t i = 0; i < config->getIntegerByKey("vehicle_count"); i ++){
        dynamics::VehicleState initial_state;
        initial_state.init_random();
        vehicle_initial_states[i] = initial_state;
    }
}

std::shared_ptr<CombinedSearchNode> SimpleRoutePlanner::get_results(){
    return solution;
}
