#include <MPCompute/MPCompute.hpp>
#include <Planner/CBSPlanner.hpp>
#include <Collision/SweepAndPrune.hpp>
#include <iostream>
#include <chrono>
#include <random>

using std::chrono::duration_cast;
using std::chrono::milliseconds;
using std::chrono::system_clock;

int main() {
    CBSPlanner planner;
    std::cout << "Loading graph from disk!" << std::endl;
    planner.mp_comp.loadGraphFromDisk();
    std::cout << "Finished loading graph from disk!" << std::endl;

    // Initialize random number generator
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> dis(0, 50); // Assuming a graph size of 50

    // Initialize the SweepAndPrune collision detector
    SweepAndPrune sweep_and_prune;

    // Test the collision detector on multiple random start and target locations
    for (int test = 0; test < 10; ++test) {
        dynamics::data::PoseByIndex start = {dis(gen), dis(gen), dis(gen), dis(gen)};
        dynamics::data::PoseByIndex end = {dis(gen), dis(gen), dis(gen), dis(gen)};
        
        auto res = planner.astar(start, end, std::vector<dynamics::data::PBIConstraint>());

        if (!res.path) {
            std::cout << "No path found for test " << test << std::endl;
            continue;
        }

        // Check for collisions along the generated path
        for (size_t i = 1; i < res.path->size(); ++i) {
            auto path_segment1 = planner.interpolatePathSegment(res.spline.at(i - 1), res.spline.at(i));
            for (size_t j = 1; j < res.path->size(); ++j) {
                auto path_segment2 = planner.interpolatePathSegment(res.spline.at(j - 1), res.spline.at(j));

                auto collision_info = sweep_and_prune.checkForCollision(path_segment1, path_segment2);

                if (collision_info.collision_occurred) {
                    std::cout << "Collision detected in test " << test << std::endl;
                    std::cout << "Collision occurred between path segments " << i << " and " << j << std::endl;
                    std::cout << "Collision indices: " << collision_info.index1 << ", " << collision_info.index2 << std::endl;
                }
            }
        }
    }

    return 0;
}
